# Django Secret Key - generate a unique key for production
SECRET_KEY=your-secret-key-here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL for production, SQLite for dev)
# Example: DATABASE_URL=postgres://user:password@localhost:5432/gestor_pedidos
DATABASE_URL=sqlite:///db.sqlite3

# Redis Cache (for production, optional)
# REDIS_URL=redis://localhost:6379/0
